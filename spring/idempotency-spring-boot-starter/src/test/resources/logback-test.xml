<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} -- %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress idempotency library logs during tests; behavior is asserted, not logged -->
    <logger name="io.github.josipmusa.idempotency" level="OFF"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
